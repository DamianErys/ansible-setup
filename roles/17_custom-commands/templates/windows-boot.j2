#!/bin/bash
# windows-boot - One-time boot to Windows, default stays Fedora

# 1. Force the EFI NextBoot variable (Most reliable for bypassing GRUB quirks)
echo "Setting EFI BootNext to 0000 (Windows)..."
sudo efibootmgr -n 0000 > /dev/null

# 2. Tell GRUB the next boot is Windows, but don't touch the permanent default
# We use the index 0 here if Windows is the first item after Fedora, 
# but using the name is safer.
WINDOWS_TITLE="Windows Boot Manager (on /dev/nvme1n1p1)"
sudo grub2-reboot "$WINDOWS_TITLE"

echo "Rebooting into Windows. Fedora remains your permanent default."
sudo reboot